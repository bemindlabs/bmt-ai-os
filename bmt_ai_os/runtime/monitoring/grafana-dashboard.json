        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(bmt_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{ endpoint }}",
          "refId": "C"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
