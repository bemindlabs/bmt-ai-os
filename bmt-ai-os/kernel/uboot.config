# BMT AI OS — U-Boot default environment
# Target: ARM64 SBCs (Jetson Orin Nano Super, RK3588, Raspberry Pi 5)
#
# This file is passed to U-Boot via:
#   CONFIG_EXTRA_ENV_SETTINGS in board-specific U-Boot defconfig, or
#   loaded at runtime from /boot/uEnv.txt on the first FAT partition.
#
# Key load addresses are chosen to avoid conflicts with:
#   - ATF (BL31) at 0x00040000
#   - OP-TEE at 0x08400000
#   - U-Boot itself at 0x00200000 (typical)
# Adjust per vendor BSP memory map if needed.

# =============================================================================
# CONSOLE
# =============================================================================

# Default serial console baud rate (all three Tier-1 boards use 115200)
baudrate=115200

# Serial console device; override in board uEnv.txt for UART index
console=ttyS0,115200n8

# =============================================================================
# LOAD ADDRESSES (ARM64, DDR starts at 0x08000000 on most SBCs)
# =============================================================================

# Kernel Image (uncompressed ARM64 Image or gzip Image.gz)
kernel_addr_r=0x40080000

# Flattened Device Tree blob (.dtb)
fdt_addr_r=0x4FA00000

# Initramfs / initrd (optional; set to - to skip)
ramdisk_addr_r=0x4FC00000

# Script address for boot.scr
scriptaddr=0x43C00000

# PXE / distro boot config buffer
pxefile_addr_r=0x43C00000

# =============================================================================
# BOOT SOURCE PRIORITY
# =============================================================================

# Try: SD card → eMMC → NVMe → USB → TFTP
boot_targets=mmc0 mmc1 nvme0 usb0 pxe dhcp

# =============================================================================
# FILESYSTEM & PARTITION
# =============================================================================

# Boot partition number on MMC (FAT32 with kernel + dtb + uEnv.txt)
boot_part=1

# Root partition number (ext4 rootfs)
root_part=2

# Root filesystem device (override in uEnv.txt for nvme0n1p2 etc.)
# Examples:
#   mmcblk0p2   — SD card
#   mmcblk1p2   — eMMC
#   nvme0n1p2   — NVMe SSD
rootdev=mmcblk0p2

# Root filesystem type
rootfstype=ext4

# Extra kernel command-line arguments appended after rootfs args
extra_bootargs=cma=256M@0x400000000 clk_ignore_unused

# =============================================================================
# DEVICE TREE
# =============================================================================

# Board-specific DTB filename; override in uEnv.txt for your board:
#   Jetson Orin Nano Super: tegra234-p3767-0005-p3768-0000-a0.dtb
#   RK3588 (Rock 5B):       rk3588-rock-5b.dtb
#   Raspberry Pi 5:         bcm2712-rpi-5-b.dtb
fdtfile=board.dtb

# DTB overlay directory on boot partition
fdtoverlay_dir=/overlays

# =============================================================================
# KERNEL COMMAND LINE
# =============================================================================

# Base arguments present on all boards
bootargs_base=console=${console} root=/dev/${rootdev} rootfstype=${rootfstype} rootwait ro quiet

# NPU / accelerator-specific args (appended per board via uEnv.txt)
# Jetson: add "tegra_chipid=0x23 nvidia-gpu-fwpath=/lib/firmware"
# RK3588: add "coherent_pool=2M rockchip_npu_mem=512M"
# Pi 5:   add "pcie_aspm=off" for Hailo M.2

# Full bootargs constructed at boot time
bootargs=${bootargs_base} ${extra_bootargs}

# =============================================================================
# BOOT COMMANDS
# =============================================================================

# Load kernel, DTB, and optional overlays from FAT boot partition, then boot
bootcmd_mmc=\
  echo "BMT AI OS: booting from ${devtype} ${devnum}:${boot_part}";\
  load ${devtype} ${devnum}:${boot_part} ${kernel_addr_r} /Image &&\
  load ${devtype} ${devnum}:${boot_part} ${fdt_addr_r} /${fdtfile} &&\
  booti ${kernel_addr_r} - ${fdt_addr_r}

# Distro boot (searches for /boot/boot.scr or /boot/extlinux/extlinux.conf)
bootcmd_distro=run distro_bootcmd

# Primary boot command: try user script (uEnv.txt), then distro boot, then MMC
bootcmd=\
  if load ${devtype} ${devnum}:${boot_part} ${scriptaddr} /uEnv.txt; then\
    env import -t ${scriptaddr} ${filesize};\
  fi;\
  run bootcmd_distro || run bootcmd_mmc

# =============================================================================
# TFTP / NETWORK BOOT (development / factory provisioning)
# =============================================================================

# TFTP server IP; set from DHCP or override here
serverip=192.168.1.1

# Board IP for static fallback
ipaddr=192.168.1.100

# TFTP boot: load kernel + dtb from server, then boot
bootcmd_tftp=\
  dhcp ${kernel_addr_r} ${serverip}:Image &&\
  tftp ${fdt_addr_r} ${serverip}:${fdtfile} &&\
  booti ${kernel_addr_r} - ${fdt_addr_r}

# =============================================================================
# FASTBOOT / RECOVERY
# =============================================================================

# Fastboot partition layout (used by factory flash scripts)
fastboot_raw_partition_bootloader=0x0 0x1000000
fastboot_partition_boot=boot
fastboot_partition_rootfs=rootfs
fastboot_partition_data=data

# =============================================================================
# MISC
# =============================================================================

# Boot delay (seconds); set to 0 for production, 3 for development
bootdelay=3

# Enable ANSI color in U-Boot console (helpful for dev boards)
stdout=serial,vidconsole
stderr=serial,vidconsole

# Maximum kernel image size check (256 MB)
kernel_comp_size=0x10000000
kernel_comp_addr_r=0x44000000
