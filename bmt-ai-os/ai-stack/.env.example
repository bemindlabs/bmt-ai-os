# BMT AI OS — AI Stack Environment Configuration
# Copy to .env.local for local overrides (not committed)

# Device tier: lite | standard | full
BMT_DEVICE_TIER=standard

# Ollama configuration
OLLAMA_HOST=0.0.0.0
OLLAMA_PORT=11434
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=5m
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b-instruct-q4_K_M

# Ollama resource limits (standard tier defaults)
OLLAMA_CPU_LIMIT=4.0
OLLAMA_MEM_LIMIT=8g

# ChromaDB configuration
CHROMADB_HOST=0.0.0.0
CHROMADB_PORT=8000

# ChromaDB resource limits (standard tier defaults)
CHROMADB_CPU_LIMIT=2.0
CHROMADB_MEM_LIMIT=1g

# ChromaDB authentication (empty = no auth, for single-device use)
CHROMA_AUTH_PROVIDER=
CHROMA_AUTH_CREDENTIALS=
