# BMT AI OS — Apple Silicon Kernel Config Fragment
# Applied via BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES alongside linux.config.
# Base kernel: Asahi Linux (https://github.com/AsahiLinux/linux), >= 6.14
#
# Target SoCs: Apple T8103 (M1), T6000/T6001 (M1 Pro/Max/Ultra),
#              T8112 (M2), T6020/T6021 (M2 Pro/Max/Ultra),
#              T8122 (M3), T6030/T6031 (M3 Pro/Max/Ultra),
#              T8132 (M4), T6040/T6041 (M4 Pro/Max/Ultra)
#
# BMTOS-43 | Epic: BMTOS-EPIC-4 (Hardware Board Support Packages)

# =============================================================================
# === Apple SoC Platform Support ===
# =============================================================================

# Top-level Apple ARM SoC platform (replaces generic ARCH_VIRT for Apple hw)
CONFIG_ARCH_APPLE=y

# Apple SoC-specific drivers — mailbox, pinctrl, power management
CONFIG_APPLE_MAILBOX=y
CONFIG_APPLE_RTKIT=y
CONFIG_APPLE_MBOX=y

# Apple GPIO / pinmux (required for peripheral enumeration)
CONFIG_PINCTRL_APPLE_GPIO=y
CONFIG_PINCTRL_APPLE=y
CONFIG_GPIO_APPLE=y

# Apple DART (Device Address Resolution Table) — IOMMU for DMA safety
CONFIG_APPLE_DART=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU_V3=y

# Apple Interrupt Controller (AIC v2 on M1+)
CONFIG_APPLE_AIC=y
CONFIG_APPLE_AIC2=y

# Apple SoC clocks
CONFIG_CLK_APPLE=y

# Apple SoC watchdog
CONFIG_APPLE_WATCHDOG=y

# Apple SoC PMU / power domains
CONFIG_APPLE_PMGR_PWRSTATE=y

# =============================================================================
# === Asahi DRM — Display Only (NO GPU Compute) ===
# =============================================================================
# The Asahi DRM driver provides display output via the Apple SoC's GPU
# (AGX/Scarlett). As of kernel 6.14, Vulkan 1.3 conformance is achieved
# for rendering, but Metal compute and OpenCL are NOT available on Linux.
# BMT AI OS uses this for display output ONLY — all AI inference is CPU-only.

CONFIG_DRM=y
CONFIG_DRM_APPLE=y
CONFIG_DRM_ASAHI=y

# Simple DRM framebuffer (fallback if Asahi DRM is not fully initialised)
CONFIG_DRM_SIMPLEDRM=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# DRM display connectors (HDMI/DP via Thunderbolt)
CONFIG_DRM_DISPLAY_CONNECTOR=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_DP_AUX_BUS=y

# Explicitly DISABLE GPU compute interfaces — not supported on Asahi Linux
# CONFIG_DRM_ASAHI_COMPUTE is not set
# CONFIG_OPENCL is not set

# =============================================================================
# === Apple NVMe (Internal SSD) ===
# =============================================================================
# Apple Silicon uses a custom NVMe variant accessed via ANS2 (Apple NVME
# Storage) with a proprietary PCIe-attached controller.

CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_APPLE_ANS_NVM=y

# =============================================================================
# === Apple PCIe ===
# =============================================================================
# Apple Silicon uses a custom PCIe host controller (APCIE) for NVMe,
# USB, Thunderbolt, and WiFi/BT. Required for most peripheral access.

CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIE_APPLE=y
CONFIG_PCIE_APPLE_MSI=y

# PCIe power management
CONFIG_PCIEASPM=y
CONFIG_PCIEASPM_POWERSAVE=y

# =============================================================================
# === USB Type-C / Thunderbolt ===
# =============================================================================
# Apple Silicon uses Thunderbolt 3/4 ports via the ANS2 controller.
# USB4 host controller driver required for USB-C peripherals.

CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_TYPEC=y
CONFIG_USB_TYPEC_ALTMODE=y
CONFIG_USB_TYPEC_DP_ALTMODE=y
CONFIG_TYPEC_APPLE=y
CONFIG_USB4=y
CONFIG_USB4_KUNIT_TEST=n

# USB Type-C Power Delivery (PD) for external monitors and peripherals
CONFIG_USB_ROLE_SWITCH=y
CONFIG_TYPEC_MUX_GPIO_SBU=y

# Apple USB3 PHY
CONFIG_PHY_APPLE_ATCPHY=y

# =============================================================================
# === CPU Frequency Scaling (M-series big.LITTLE) ===
# =============================================================================
# M-series chips have a big.LITTLE topology:
#   P-cores (Firestorm/Everest): high-performance, used for inference
#   E-cores (Icestorm/Sawtooth): efficiency, used for OS background tasks
# cpufreq scaling allows BMT AI OS to boost P-cores to max during inference.

CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPUFREQ_DT=y
CONFIG_APPLE_SOC_CPUFREQ=y

# ARM64 CPU topology (for scheduler-aware big.LITTLE placement)
CONFIG_SCHED_MC=y
CONFIG_SCHED_MC_PRIO=y
CONFIG_ARM64_AMU_EXTN=y

# Energy-Aware Scheduling (EAS) — lets kernel prefer P-cores for heavy tasks
CONFIG_ENERGY_MODEL=y

# =============================================================================
# === NEON / ASIMD (ARM64 SIMD for llama.cpp / GGML) ===
# =============================================================================
# All M-series cores support NEON/ASIMD. The GGML CPU backend in llama.cpp
# and Ollama auto-detects and uses ASIMD for matrix multiply acceleration.
# These options are on by default for aarch64 but listed for clarity.

CONFIG_ARM64_CRYPTO=y
CONFIG_CRYPTO_AES_ARM64_CE=y
CONFIG_CRYPTO_SHA2_ARM64_CE=y

# =============================================================================
# === Apple Storage & I2C (for keyboard, touchpad on MacBook targets) ===
# =============================================================================

CONFIG_I2C=y
CONFIG_I2C_APPLE=y

# SPI (for internal keyboard/touchpad on MacBook targets)
CONFIG_SPI=y
CONFIG_SPI_APPLE=y

# Apple SPI HID transport (keyboard, trackpad)
CONFIG_HID_APPLE=y
CONFIG_APPLE_SPI_KEYBOARD=y

# =============================================================================
# === Apple WiFi / Bluetooth (BCM4387 / BCM4388 via PCIe) ===
# =============================================================================
# WiFi and BT share a PCIe-attached Broadcom BCM4387 / BCM4388 chip.
# Firmware is required (extracted via asahi-firmware-extract).

CONFIG_WLAN=y
CONFIG_BRCMFMAC=m
CONFIG_BRCMFMAC_PCIE=y
CONFIG_BRCMUTIL=m

CONFIG_BT=m
CONFIG_BT_HCIBTUSB=m
CONFIG_BT_HCIBCM4377=m

# =============================================================================
# === Power Management (for MacBook / Mac Studio targets) ===
# =============================================================================

CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_SUSPEND=y
CONFIG_HIBERNATION=n

# Apple SMC / MFI (for battery, power button on MacBook targets)
CONFIG_APPLE_SMC=y
CONFIG_APPLE_SMC_CHARGER=y
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY_APPLE_SMC=y

# =============================================================================
# === RTC ===
# =============================================================================
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_APPLE=y

# =============================================================================
# === Miscellaneous Apple-specific ===
# =============================================================================

# Apple SART (Secure Address Resolution Table) — for NVMe DMA mapping
CONFIG_APPLE_SART=y

# Apple SEP (Secure Enclave Processor) — random number generation
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_APPLE=y

# Apple SIO (low-speed I/O DMA controller)
CONFIG_APPLE_SIO=y

# SPMI (System Power Management Interface) — for PMIC access on M-series
CONFIG_SPMI=y
CONFIG_SPMI_APPLE=y

# Thermal management — prevent throttling during long inference runs
CONFIG_THERMAL=y
CONFIG_APPLE_SOC_TEMP=y
CONFIG_CPU_THERMAL=y
