# BMT AI OS — Linux kernel config fragment
# Applied on top of the board vendor defconfig via BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES
# Architecture: ARM64 (aarch64)
# Kernel: 6.x LTS (linux-longterm)
#
# Usage in Buildroot:
#   BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_BMT_PATH)/kernel/linux.config"

# =============================================================================
# CONTAINER RUNTIME — OverlayFS, Namespaces, Cgroups
# Required by: containerd, Docker engine
# =============================================================================

# OverlayFS — container image layer storage
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_XINO_AUTO=y

# Cgroups v2 — resource isolation for containers and AI workloads
CONFIG_CGROUPS=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_RDMA=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CPUSETS=y
CONFIG_PROC_PID_CPUSET=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_MISC=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y

# Namespaces — full isolation (pid, net, mnt, uts, ipc, user)
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_TIME_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# =============================================================================
# FILESYSTEMS
# Required by: container image storage, devpts inside containers
# =============================================================================

CONFIG_DEVPTS_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_HUGETLBFS=y
CONFIG_CONFIGFS_FS=y

# ext4 — host rootfs and data volumes
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y

# =============================================================================
# NETWORKING — Bridge, VETH, Netfilter / iptables
# Required by: Docker bridge networking, Compose inter-container DNS
# =============================================================================

# Virtual network devices
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_DUMMY=y
CONFIG_TUN=y
CONFIG_MACVLAN=y
CONFIG_IPVLAN=y

# Netfilter core
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_MARK=y
CONFIG_NF_CONNTRACK_EVENTS=y
CONFIG_NF_CT_PROTO_DCCP=y
CONFIG_NF_CT_PROTO_SCTP=y
CONFIG_NF_CT_PROTO_UDPLITE=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_MASQUERADE=y

# iptables (IPv4 NAT, masquerade, port-forward)
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_MANGLE=y

# iptables (IPv6)
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_TARGET_REJECT=y
CONFIG_IP6_NF_MANGLE=y

# nftables (preferred by newer iptables-nft front-end)
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NF_TABLES_BRIDGE=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_CT=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y

# IP routing required for NAT and inter-service traffic
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_IP6_ADVANCED_ROUTER=y

# IPVS — optional; needed if using Kubernetes kube-proxy in IPVS mode
CONFIG_IP_VS=m
CONFIG_IP_VS_RR=m
CONFIG_IP_VS_NFCT=y

# =============================================================================
# SECURITY
# Required by: container runtime security, OCI seccomp profiles
# =============================================================================

CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_KEYS=y
CONFIG_KEYS_REQUEST_CACHE=y
CONFIG_PERSISTENT_KEYRINGS=y
CONFIG_BIG_KEYS=y

# LSM (enable AppArmor as default; SELinux disabled to save flash)
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_PATH=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y

# Capabilities (required by rootless containers)
CONFIG_MULTIUSER=y
CONFIG_FILE_CAPABILITIES=y

# =============================================================================
# BPF / eBPF
# Required by: containerd network plugins, observability
# =============================================================================

CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_DEFAULT_ON=y
CONFIG_BPF_EVENTS=y
CONFIG_NET_CLS_BPF=m
CONFIG_NET_ACT_BPF=m
CONFIG_BPFILTER=y

# =============================================================================
# NPU / ACCELERATOR DEVICE ACCESS
# ARM64 target hardware: Jetson Orin Nano Super, RK3588, Pi 5 + Hailo
# Actual driver modules are supplied by vendor BSP layers; these options
# ensure the kernel framework is present for udev and devfs.
# =============================================================================

# V4L2 media framework (used by RKNN / HailoRT capture pipelines)
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_V4L_PLATFORM_DRIVERS=y

# DMA-BUF sharing between CPU and NPU
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y

# CMA — contiguous memory allocator for DMA to NPU/GPU buffers
CONFIG_CMA=y
CONFIG_CMA_SIZE_MBYTES=256
CONFIG_DMA_CMA=y

# IOMMU — required for Jetson SMMU and RK3588 IOMMU passthrough
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y

# PCIe (Hailo-8 M.2 on Pi 5 uses PCIe)
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIEASPM=y
CONFIG_PCIE_BRCMSTB=y

# USB (Hailo USB variant, USB cameras)
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y

# GPIO / I2C / SPI (sensor bus for edge AI boards)
CONFIG_GPIO_SYSFS=y
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_SPI=y
CONFIG_SPI_SPIDEV=y

# NVME / UFS — fast local storage for model weights
CONFIG_BLK_DEV_NVME=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFSHCD_PLATFORM=y

# =============================================================================
# POWER MANAGEMENT
# ARM64 SBCs require dynamic frequency scaling for sustained AI inference
# =============================================================================

CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_IDLE=y
CONFIG_ARM_CPUIDLE=y

# =============================================================================
# MISC KERNEL FEATURES
# =============================================================================

# POSIX message queues (used by some AI framework IPC)
CONFIG_POSIX_MQUEUE=y

# FUSE — useful for overlay network drivers and SSHFS development mounts
CONFIG_FUSE_FS=y

# Kernel compression: LZ4 for fast boot on flash storage
CONFIG_KERNEL_LZ4=y

# Printk and debug (keep for production logs; strip KGDB)
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_DYNAMIC_DEBUG=y
# CONFIG_KGDB is not set

# High-resolution timers — required for accurate AI inference benchmarking
CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_HIGH_RES_TIMERS=y

# VDSO on ARM64
CONFIG_COMPAT_VDSO=y
