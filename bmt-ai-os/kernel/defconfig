# BMT AI OS — Buildroot defconfig
# Architecture: ARM64 (aarch64)

# === Architecture & Kernel ===
BR2_aarch64=y
BR2_KERNEL_HEADERS_LATEST=y

# Kernel features for containers
# CONFIG_OVERLAY_FS=y
# CONFIG_CGROUPS=y
# CONFIG_NAMESPACES=y
# CONFIG_BRIDGE=y
# CONFIG_VETH=y
# CONFIG_NETFILTER=y

# === Init System ===
BR2_INIT_OPENRC=y

# === Container Runtime ===
BR2_PACKAGE_DOCKER_CLI=y
BR2_PACKAGE_CONTAINERD=y
BR2_PACKAGE_IPTABLES=y
BR2_PACKAGE_BRIDGE_UTILS=y
BR2_PACKAGE_DNSMASQ=y

# === Python Stack ===
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_PYTHON3_PIP=y
BR2_PACKAGE_PYTHON3_DEV=y
BR2_PACKAGE_PYTHON3_VENV=y
BR2_PACKAGE_PYTHON3_SETUPTOOLS=y
BR2_PACKAGE_PYTHON3_SQLITE3=y

# === AI Training & ML Framework Support ===
BR2_PACKAGE_PYTHON3_NUMPY=y
BR2_PACKAGE_OPENBLAS=y

# === Node.js Ecosystem ===
BR2_PACKAGE_NODEJS=y
BR2_PACKAGE_NPM=y

# === Build Tools ===
BR2_PACKAGE_MAKE=y
BR2_PACKAGE_GCC=y
BR2_PACKAGE_CMAKE=y
BR2_PACKAGE_PKG_CONFIG=y

# === Networking ===
BR2_PACKAGE_CURL=y
BR2_PACKAGE_WGET=y
BR2_PACKAGE_OPENSSH=y
BR2_PACKAGE_AVAHI=y
BR2_PACKAGE_CA_CERTIFICATES=y
BR2_PACKAGE_OPENSSL=y

# === Storage & Filesystem ===
BR2_PACKAGE_E2FSPROGS=y
BR2_PACKAGE_PARTED=y
BR2_PACKAGE_UTIL_LINUX=y

# === Security ===
BR2_PACKAGE_GNUPG=y

# === Hardware Detection & Monitoring ===
BR2_PACKAGE_I2C_TOOLS=y
BR2_PACKAGE_LM_SENSORS=y
BR2_PACKAGE_USBUTILS=y

# === Developer Tools ===
BR2_PACKAGE_GIT=y
BR2_PACKAGE_HTOP=y
BR2_PACKAGE_NANO=y
BR2_PACKAGE_TMUX=y
BR2_PACKAGE_LESS=y

# === Hardware-Specific (enable per BSP) ===
# Jetson Orin:  BR2_PACKAGE_CUDA=y BR2_PACKAGE_TENSORRT_LLM=y
# RK3588:       BR2_PACKAGE_RKNN_RUNTIME=y BR2_PACKAGE_RKLLM=y
# Pi 5 + Hailo: BR2_PACKAGE_HAILO_RUNTIME=y
