# BMT AI OS — Raspberry Pi 5 + Hailo AI HAT+ 2 kernel config fragment
#
# Applied on top of the base linux.config fragment via:
#   BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_BMT_AI_OS_PATH)/../../bmt_ai_os/kernel/linux.config \
#     $(BR2_EXTERNAL_BMT_AI_OS_PATH)/../../bmt_ai_os/kernel/pi5-hailo.config"
#
# Covers:
#   - BCM2712 (Raspberry Pi 5) platform support
#   - PCIe Gen3 for Hailo-10H AI HAT+ 2
#   - VideoCore VII GPU (V3D, DRM/KMS)
#   - Pi 5 thermal management
#   - USB, SD/eMMC, UART, SPI, I2C peripherals
#   - Hailo PCIe accelerator driver (hailo_pci)
#
# Kernel branch: rpi-6.6.y (Raspberry Pi Foundation fork)
# Defconfig base: bcm2712_defconfig
#
# BMTOS-28 | Epic: BMTOS-EPIC-4 (Hardware Board Support Packages)

# =============================================================================
# BCM2712 Platform / Raspberry Pi 5 SoC Support
# =============================================================================

# Broadcom BCM27xx family SoC support (required for Pi 5)
CONFIG_ARCH_BCM=y
CONFIG_ARCH_BCM2835=y

# BCM2712 is a BCM2711 successor; the Pi Foundation kernel enables it via
# the ARCH_BCM2835 umbrella + device-tree board files.
CONFIG_BCM2712=y

# ARM Cortex-A76 CPU support (4 cores @ up to 2.4 GHz)
CONFIG_ARM64=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y

# =============================================================================
# PCIe — Required for Hailo-10H AI HAT+ 2
# =============================================================================

# PCIe subsystem core
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIEAER=y
CONFIG_PCIEASPM=y
CONFIG_PCIEASPM_POWERSAVE=y

# Broadcom STB PCIe host controller (used on BCM2712 for the M.2 PCIe slot)
CONFIG_PCIE_BRCMSTB=y

# PCIe Gen3 x1 — Hailo-10H requires at minimum PCIe Gen2 x1
# BCM2712 exposes a PCIe Gen3 x1 lane to the M.2 2242 connector
CONFIG_PCIE_BRCMSTB_MSI=y

# MSI/MSI-X interrupt support — HailoRT requires MSI
CONFIG_PCI_MSI=y
CONFIG_PCI_MSI_IRQ_DOMAIN=y

# DMA mapping for PCIe devices
CONFIG_PCI_DMA_HELPER=y

# =============================================================================
# Hailo PCIe Accelerator Driver (hailo_pci)
# =============================================================================
# The hailo_pci driver is maintained out-of-tree by Hailo Technologies.
# It is built as a module (=m) to allow DKMS-based updates independently
# of the kernel version.
#
# The driver can also be built in-tree if the HailoRT driver source is
# patched into the kernel source tree via BR2_LINUX_KERNEL_CUSTOM_PATCH_DIR.

# Enable misc device framework (hailo_pci registers as a misc device)
CONFIG_MISC_DEVICES=y

# Memory management required for DMA to/from Hailo-10H
CONFIG_DMA_SHARED_BUFFER=y
CONFIG_DMA_CMA=y
# CMA pool for Hailo NPU inference buffers — 256 MB minimum on 4 GB boards,
# increase to 512 MB on 8 GB boards for larger batch sizes
CONFIG_CMA_SIZE_MBYTES=256

# IOMMU (ARM SMMU) — required for PCIe DMA isolation
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y

# =============================================================================
# VideoCore VII GPU (V3D / DRM/KMS)
# =============================================================================
# The BCM2712 includes a VideoCore VII GPU supporting OpenGL ES 3.1 and
# Vulkan 1.2. On BMT AI OS this is used only for the dashboard display output;
# AI inference is offloaded entirely to the Hailo-10H NPU.

CONFIG_DRM=y
CONFIG_DRM_V3D=y
CONFIG_DRM_VC4=y
CONFIG_DRM_VC4_HDMI=y

# Display output (HDMI)
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FB_SIMPLE=y

# DRM KMS (Kernel Mode Setting)
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_KMS_FB_HELPER=y

# V4L2 video devices (camera input, media controller)
CONFIG_VIDEO_V4L2=y
CONFIG_MEDIA_SUPPORT=y
CONFIG_VIDEO_DEV=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_V4L_PLATFORM_DRIVERS=y

# =============================================================================
# Raspberry Pi 5 Thermal Management
# =============================================================================

# Thermal framework core
CONFIG_THERMAL=y
CONFIG_THERMAL_STATISTICS=y
CONFIG_THERMAL_WRITABLE_TRIPS=y
CONFIG_THERMAL_DEFAULT_GOV_STEP_WISE=y
CONFIG_CPU_THERMAL=y

# BCM2835 thermal sensor driver (shared with Pi 5 via BCM27xx platform layer)
CONFIG_BCM2835_THERMAL=y

# HWMON for temperature reporting to userspace (/sys/class/thermal)
CONFIG_HWMON=y
CONFIG_SENSORS_RASPBERRYPI_HWMON=y

# CPU frequency scaling — Cortex-A76 supports 1.5–2.4 GHz dynamic range
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
# Use 'performance' governor by default for consistent AI inference latency
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y

# ARM cpufreq driver
CONFIG_ARM_CPUFREQ=y
CONFIG_ARM_SCMI_CPUFREQ=y

# =============================================================================
# USB — Raspberry Pi 5 USB 3.0 Host (xHCI)
# =============================================================================

CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

# USB Gadget (for USB OTG / device-mode console access during development)
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y

# =============================================================================
# SD Card / eMMC (SD card boot on Pi 5)
# =============================================================================

CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_IPROC=y

# =============================================================================
# GPIO, I2C, SPI, UART (Pi 5 40-pin GPIO header)
# =============================================================================

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_BCM_VIRT=y
CONFIG_GPIO_RASPBERRYPI_EXP=y

# I2C (sensors, PMICs, RTC on 40-pin header)
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_BCM2835=y
CONFIG_I2C_DESIGNWARE_PLATFORM=y

# SPI (displays, sensors, HATs)
CONFIG_SPI=y
CONFIG_SPI_SPIDEV=y
CONFIG_SPI_BCM2835=y
CONFIG_SPI_BCM2835AUX=y

# UART (serial console during development)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_OF_PLATFORM=y

# =============================================================================
# Networking (Gigabit Ethernet via PCIe, WiFi 802.11ac)
# =============================================================================

# Gigabit Ethernet (BCM54213PE PHY, connected via RP1 PCIe bridge on Pi 5)
CONFIG_NET=y
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_BROADCOM=y
CONFIG_BCMGENET=y

# WiFi — BCM43455 (dual-band 802.11ac, same chip used in Pi 4)
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMFMAC_SDIO=y
CONFIG_BRCMFMAC_PCIE=y

# =============================================================================
# Real-Time Clock
# =============================================================================

CONFIG_RTC_CLASS=y
# Raspberry Pi 5 has an onboard RTC backed by the supercapacitor
CONFIG_RTC_DRV_RPI=y
CONFIG_RTC_DRV_PCF85063=y

# =============================================================================
# Power Management
# =============================================================================

CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_SUSPEND=y
CONFIG_PM_AUTOSLEEP=y
CONFIG_ENERGY_MODEL=y

# PMIC / Voltage regulator
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_GPIO=y

# =============================================================================
# Device Tree / OF support
# =============================================================================

CONFIG_OF=y
CONFIG_OF_EARLY_FLATTREE=y
CONFIG_OF_RESERVED_MEM=y
CONFIG_OF_ADDRESS=y

# =============================================================================
# Misc / Required by BMT AI OS base linux.config (ensure no conflicts)
# =============================================================================

# High-resolution timers (required for accurate inference latency measurement)
CONFIG_HIGH_RES_TIMERS=y
CONFIG_HZ_250=y

# Random number generator (TPM2 via SPI or SW fallback)
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_BCM2835=y

# Watchdog (safety for unattended embedded operation)
CONFIG_WATCHDOG=y
CONFIG_BCM2835_WDT=y
CONFIG_WATCHDOG_HANDLE_BOOT_ENABLED=y
