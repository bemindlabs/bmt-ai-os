# BMT AI OS — Kernel Config Fragment: Jetson Orin Nano Super (Tegra234 / p3767)
#
# Applied via BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES on top of the base
# linux.config fragment. Enables NVIDIA GPU support, Tegra SoC platform
# drivers, Deep Learning Accelerator (DLA), and NVMe SSD via PCIe.
#
# Target hardware:
#   SoC:       NVIDIA Tegra234 (Cortex-A78AE x6 + Ampere GA10B GPU + 2x DLA)
#   Board:     p3767-0005 (Jetson Orin Nano Super 8GB)
#   TOPS:      67 CUDA TOPS
#   RAM:       8 GB LPDDR5 (unified CPU/GPU memory)
#   CUDA arch: sm_87 (Ampere)
#   JetPack:   6.1 (L4T 36.4.3, kernel 5.15.x Tegra downstream)
#
# BMTOS-26 | Epic: BMTOS-EPIC-4 (Hardware Board Support Packages)

# =============================================================================
# Tegra / NVIDIA SoC Platform Support
# =============================================================================

# Tegra SoC family (required for all Tegra-specific drivers)
CONFIG_ARCH_TEGRA=y
CONFIG_ARCH_TEGRA_234_SOC=y

# Tegra clock and power management
CONFIG_CLK_TEGRA=y
CONFIG_CLK_TEGRA_BPMP=y
CONFIG_TEGRA_BPMP=y
CONFIG_TEGRA_BPMP_MFD=y
CONFIG_TEGRA_HSP_MBOX=y
CONFIG_TEGRA_IVC=y

# Tegra memory controller (SMMU required for GPU DMA isolation)
CONFIG_TEGRA_MC=y

# Tegra audio (not required for AI OS, disable to save memory)
# CONFIG_TEGRA_AUDIO is not set

# =============================================================================
# NVIDIA GPU Driver (nvgpu — Tegra integrated GPU)
# =============================================================================

# nvgpu: NVIDIA GPU driver for Tegra (in-tree L4T driver)
# Provides /dev/nvhost-*, /dev/nvmap device nodes consumed by CUDA runtime.
CONFIG_TEGRA_NVGPU=y
CONFIG_TEGRA_NVGPU_NEXT=y

# GPU memory management — nvmap (Tegra-specific IOMMU-aware allocator)
CONFIG_NVMAP=y
CONFIG_NVMAP_HIGHMEM_ONLY=n
CONFIG_NVMAP_FORCE_ZEROED_USER_PAGES=y
CONFIG_NVMAP_DEFERRED_CACHE_MAINT=y
CONFIG_NVMAP_PAGE_POOLS=y
CONFIG_NVMAP_CONVERT_CARVEOUT_TO_IOVMM=y

# GPU device nodes exposed to userspace (required by CUDA SDK + containers)
CONFIG_TEGRA_HOST1X=y
CONFIG_TEGRA_GRHOST=y
CONFIG_TEGRA_GRHOST_DEFAULT_TIMEOUT=10000

# NVIDIA IOMMU / SMMU integration for GPU DMA
CONFIG_IOMMU_API=y
CONFIG_IOMMU_DMA=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y
CONFIG_TEGRA_IOMMU_SMMU=y

# =============================================================================
# Deep Learning Accelerator (DLA) — Tegra234 has 2x DLA cores
# =============================================================================

# NVDLA kernel driver — exposes /dev/nvhost-ctrl-nvdla{0,1}
# Allows TensorRT to offload INT8 layers to DLA for power efficiency
CONFIG_NVDLA=y

# DLA uses the same host1x / grhost infrastructure as GPU
# (CONFIG_TEGRA_GRHOST must be y — already set above)

# =============================================================================
# PCIe — NVMe SSD Storage (M.2 Key M slot on Orin Nano carrier board)
# =============================================================================

CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIEASPM=y
CONFIG_PCIE_TEGRA194=y
CONFIG_PCIE_TEGRA194_HOST=y
# Tegra234 uses the same Tegra194-compatible PCIe controller IP
# plus additional Tegra234-specific endpoints
CONFIG_PCIE_TEGRA194_EP=n

# NVMe host driver (required for M.2 NVMe SSDs)
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_MULTIPATH=y
CONFIG_NVME_FABRICS=m
CONFIG_NVME_RDMA=m
CONFIG_NVME_CORE=y

# AHCI / SATA (some carrier boards expose SATA via PCIe bridge)
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_SATA_AHCI_PLATFORM=y

# =============================================================================
# DMA — Zero-copy GPU/CPU memory sharing (critical for unified memory on Orin)
# =============================================================================

CONFIG_DMA_SHARED_BUFFER=y
CONFIG_DMA_CMA=y
CONFIG_CMA_SIZE_MBYTES=512
CONFIG_DMA_HEAP=y
CONFIG_DMA_HEAP_DEFAULT_ORDER=8
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y

# =============================================================================
# USB — OTG / Host (USB 3.2 on Orin Nano carrier board)
# =============================================================================

CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_TEGRA=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y

# =============================================================================
# I2C, SPI, GPIO (sensor buses for edge AI peripherals)
# =============================================================================

CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_TEGRA=y
CONFIG_SPI=y
CONFIG_SPI_SPIDEV=y
CONFIG_SPI_TEGRA114=y
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_TEGRA186=y

# =============================================================================
# Thermal management — Tegra234 has fine-grained thermal zones for GPU + CPU
# =============================================================================

CONFIG_THERMAL=y
CONFIG_TEGRA_SOCTHERM=y
CONFIG_TEGRA_BPMP_THERMAL=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
# Tegra CPUFreq driver (BPMP-based, required on Tegra234)
CONFIG_CPUFREQ_DT=y
CONFIG_ARM_TEGRA_CPUFREQ=y

# =============================================================================
# UART / Serial console (UART0 on Jetson Orin Nano carrier debug header)
# =============================================================================

CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_TEGRA=y

# =============================================================================
# Networking — Gigabit Ethernet on Jetson Orin Nano Devkit carrier
# =============================================================================

CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_R8169=y
# Tegra EQOS (built-in GbE MAC on Tegra234)
CONFIG_DWMAC_TEGRA=y
CONFIG_STMMAC_ETH=y

# =============================================================================
# Video / V4L2 — Camera input for edge vision models
# =============================================================================

CONFIG_VIDEO_V4L2=y
CONFIG_VIDEO_V4L2_SUBDEV_API=y
CONFIG_MEDIA_CONTROLLER=y
CONFIG_MEDIA_SUPPORT=y
CONFIG_VIDEO_DEV=y
# Tegra video input (VI) — MIPI CSI-2 camera capture
CONFIG_VIDEO_TEGRA_VI=y

# =============================================================================
# Misc
# =============================================================================

# Real-time clock (Tegra234 RTC for accurate timestamps in logs/training)
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_TEGRA=y

# Watchdog (required for production reliability)
CONFIG_WATCHDOG=y
CONFIG_TEGRA_WATCHDOG=y

# EDAC — ECC memory error reporting (Tegra234 DRAM controller)
CONFIG_EDAC=y
CONFIG_TEGRA_EDAC=y

# Reboot/reset via BPMP
CONFIG_POWER_RESET=y
CONFIG_POWER_RESET_SYSCON=y

# Enable perf counters for GPU/CPU profiling (optional, useful for AI tuning)
CONFIG_PERF_EVENTS=y
CONFIG_HW_PERF_EVENTS=y

# Disable debug bloat on production image
# CONFIG_STAGING is not set
