# BMT AI OS — U-Boot Default Environment
# For ARM64 SBC targets (Jetson, RK3588, Pi 5)

# Load Addresses (above ATF/OP-TEE)
kernel_addr_r=0x40080000
fdt_addr_r=0x4FA00000
ramdisk_addr_r=0x44000000
scriptaddr=0x40F00000

# Boot Targets (priority: SD → eMMC → NVMe → USB → PXE)
boot_targets=mmc0 mmc1 nvme0 usb0 pxe

# Kernel Command Line
bootargs=console=ttyS0,115200 root=LABEL=BMT_ROOTFS_A rootfstype=ext4 rootwait cgroup_enable=memory swapaccount=1

# Boot Command: uEnv.txt override → distro boot → direct booti
bootcmd=if load ${devtype} ${devnum}:1 ${scriptaddr} uEnv.txt; then env import -t ${scriptaddr} ${filesize}; fi; if run distro_bootcmd; then; else run direct_boot; fi
direct_boot=load ${devtype} ${devnum}:1 ${kernel_addr_r} Image; load ${devtype} ${devnum}:1 ${fdt_addr_r} ${fdtfile}; booti ${kernel_addr_r} - ${fdt_addr_r}

# Device Tree (per board — uncomment one or use auto)
#fdtfile=nvidia/tegra234-p3767-0003-p3768-0000-a0.dtb   # Jetson Orin
#fdtfile=rockchip/rk3588-rock-5b.dtb                     # ROCK 5B
#fdtfile=broadcom/bcm2712-rpi-5-b.dtb                    # Pi 5
fdtfile=auto

# Console
baudrate=115200
stderr=serial
stdin=serial
stdout=serial

# Boot Delay (set to 0 in production via uEnv.txt)
bootdelay=3

# TFTP Boot (development/factory)
tftp_boot=dhcp ${kernel_addr_r} Image; dhcp ${fdt_addr_r} ${fdtfile}; booti ${kernel_addr_r} - ${fdt_addr_r}
