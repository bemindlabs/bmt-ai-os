# bmt-ai-os-build/buildroot-external/Config.in
# BMT AI OS external Kconfig menu
#
# This file is sourced by Buildroot's top-level Config.in when
# BR2_EXTERNAL points to this directory. It surfaces BMT AI OS
# package options inside 'make menuconfig' under a dedicated sub-menu.

menu "BMT AI OS Packages"

comment "AI Inference"
source "$BR2_EXTERNAL_BMT_AI_OS_PATH/package/ollama/Config.in"

comment "Vector Store"
source "$BR2_EXTERNAL_BMT_AI_OS_PATH/package/chromadb/Config.in"

comment "AI Stack Controller"
source "$BR2_EXTERNAL_BMT_AI_OS_PATH/package/bmt-controller/Config.in"

comment "Hardware Acceleration (select per BSP)"
source "$BR2_EXTERNAL_BMT_AI_OS_PATH/package/bmt-npu-stub/Config.in"
source "$BR2_EXTERNAL_BMT_AI_OS_PATH/package/jetson-bsp/Config.in"
source "$BR2_EXTERNAL_BMT_AI_OS_PATH/package/rk3588-bsp/Config.in"
source "$BR2_EXTERNAL_BMT_AI_OS_PATH/package/pi5-hailo-bsp/Config.in"
source "$BR2_EXTERNAL_BMT_AI_OS_PATH/package/apple-silicon-bsp/Config.in"

endmenu
